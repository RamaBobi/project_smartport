    </inertial>
  </link>

  <!-- ── TRAILER SUSPENSION BARS (visual, mirrors tractor copy_truck) ─────
       Each bar hangs from its rail at the wheel-X position, shifted
       0.185 m inboard (= wheel_width/2 + bar_width/2 = 0.15 + 0.035) so
       it sits flush against the inner face of the wheel disc.
       Bar centre at Z=-0.25 → spans rail Z=0 down to hub Z=-0.5.
  ─────────────────────────────────────────────────────────────────────── -->

  <!-- Trailer FRONT-TANDEM LEFT bar (rail-frame X=-2.5, Y=+0.115) -->
  <joint name="trailer_left_rail_to_tfl_suspension_bar" type="fixed">
    <parent link="trailer_left_rail"/>
    <child link="tfl_suspension_bar"/>
