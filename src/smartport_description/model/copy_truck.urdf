    <collision><geometry><cylinder radius="0.5" length="0.3"/></geometry></collision>
    <inertial><mass value="80.0"/><inertia ixx="5.6" ixy="0" ixz="0" iyy="5.6" iyz="0" izz="10.0"/></inertial>
  </link>

  <!-- ============================================================== -->
  <!-- 6.  TRAILER HITCH (revolute, Z axis = yaw)                      -->
  <!--     Pre-rotated +45° via origin rpy so trailer spawns at MAX.   -->
  <!--     Joint angle range: -pi/2 .. 0 (world yaw range: -45°..+45°) -->
  <!--     To reset: rpy="0 0 0" and limit ±0.7854                     -->
  <!-- ============================================================== -->
  <joint name="trailer_hitch" type="revolute">
    <parent link="chassis"/>
    <child link="trailer_base"/>
    <origin xyz="-2.0 0 0" rpy="0 0 0.7854"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.5708" upper="0" effort="20000" velocity="2.0"/>
    <dynamics damping="200.0" friction="50.0"/>
  </joint>
  <link name="trailer_base">
    <visual>
      <geometry><cylinder radius="0.15" length="0.5"/></geometry>
      <material name="hitch_yellow"><color rgba="0.95 0.75 0.1 1.0"/></material>
    </visual>
    <inertial>
      <mass value="500.0"/>
      <inertia ixx="83" ixy="0" ixz="0" iyy="208" iyz="0" izz="208"/>
    </inertial>
  </link>

  <!-- ============================================================== -->
  <!-- 7.  TRAILER H FRAME  (8 m rails span X=[-8, 0] in trailer_base) -->
  <!-- ============================================================== -->

