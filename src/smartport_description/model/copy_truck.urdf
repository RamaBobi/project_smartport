<?xml version="1.0"?>
<!--
  copy_truck.urdf  –  Physics-optimised port tractor (TRACTOR ONLY, no trailer).
  ─────────────────────────────────────────────────────────────────────────────
  Geometry is identical to tractor.urdf.
  Every change from the original is marked  [PHYSICS] with the reason.

  Summary of changes:
  ┌─────────────────────────────────────────────────────────────────────────┐
  │ 1. Chassis hub inertia corrected  (was 333/541/541 → 555/390/915 kg·m²) │
  │ 2. Driver deck inertia corrected  (was 135/187/135 → 229/187/229 kg·m²) │
  │    Bug: original missed Z² in Ixx and Izz formulas.                     │
  │ 3. Suspension spring stiffness    100 000 → 70 000 N/m                  │
  │    Reason: 100 kN/m gives fn≈2.2 Hz; target is 1.5 Hz for a truck.      │
  │    k = (2π·1.5)²·m_per_wheel = 88.8·777 ≈ 70 000 N/m                   │
  │    Damping kept at 4500 → ζ≈0.31 (lightly underdamped) ✓                │
  │ 4. Per-wheel contact surface      rubber-on-concrete (mu=0.85/0.75)     │
  │    kp=1e6 N/m, kd=50, slip1=0.002, slip2=0.005, minDepth=0.002 m        │
  │ 5. Steering joint friction        5.0 → 1.5 Nm (less stiction)          │
  │ 6. Steering servo PID             p 500→1500, i 1→2, d 50→100           │
  │ 7. Trailer reattached             4 wheels w/ k=70000 + PID + bars       │
  └─────────────────────────────────────────────────────────────────────────┘

  Inertia reference:  solid box I = m(a²+b²)/12  for off-axis pair a,b.
  Inertia reference:  solid cylinder Ixx=Iyy = m(3r²+l²)/12, Izz = mr²/2.
-->
<robot name="copy_truck" xmlns:xacro="http://ros.org/wiki/xacro">

  <!-- ============================================================== -->
  <!-- 1.  ROOT & CHASSIS HUB                                          -->
  <!-- ============================================================== -->
  <link name="base_link"/>
  <joint name="base_joint" type="fixed">
    <parent link="base_link"/>
    <child link="chassis"/>
    <origin xyz="0 0 1.0" rpy="0 0 0"/>
  </joint>

  <link name="chassis">
    <inertial>
      <mass value="2000.0"/>
      <!--
        [PHYSICS] Corrected. chassis is the structural hub tying the frame.
        Modelled as a hollow box  1.5 m (X) × 1.8 m (Y) × 0.3 m (Z):
          Ixx = 2000*(1.8²+0.3²)/12 = 2000*3.33/12  =  555  kg·m²
          Iyy = 2000*(1.5²+0.3²)/12 = 2000*2.34/12  =  390  kg·m²
          Izz = 2000*(1.5²+1.8²)/12 = 2000*5.49/12  =  915  kg·m²
        (was 333 / 541 / 541 – too low, caused wobble at low speed)
      -->
      <inertia ixx="555" ixy="0" ixz="0"
               iyy="390" iyz="0"
               izz="915"/>
    </inertial>
  </link>

  <!-- ============================================================== -->
  <!-- 2.  TRUCK H FRAME  (rails unchanged – inertias already correct) -->
  <!-- ============================================================== -->

  <joint name="chassis_to_left_rail" type="fixed">
    <parent link="chassis"/>
    <child link="left_rail"/>
    <origin xyz="0 0.9 0" rpy="0 0 0"/>
  </joint>
  <link name="left_rail">
    <visual>
      <geometry><box size="4.0 0.2 0.3"/></geometry>
      <material name="dark_grey"><color rgba="0.2 0.2 0.2 1.0"/></material>
    </visual>
    <collision><geometry><box size="4.0 0.2 0.3"/></geometry></collision>
    <inertial>
      <mass value="600.0"/>
      <!-- box 4.0×0.2×0.3: Ixx=6.5 Iyy=804.5 Izz=802 — already correct -->
      <inertia ixx="6.5" ixy="0" ixz="0" iyy="804.5" iyz="0" izz="802"/>
    </inertial>
  </link>

  <joint name="chassis_to_right_rail" type="fixed">
    <parent link="chassis"/>
    <child link="right_rail"/>
    <origin xyz="0 -0.9 0" rpy="0 0 0"/>
  </joint>
  <link name="right_rail">
    <visual>
      <geometry><box size="4.0 0.2 0.3"/></geometry>
      <material name="dark_grey"><color rgba="0.2 0.2 0.2 1.0"/></material>
    </visual>
    <collision><geometry><box size="4.0 0.2 0.3"/></geometry></collision>
    <inertial>
      <mass value="600.0"/>
      <inertia ixx="6.5" ixy="0" ixz="0" iyy="804.5" iyz="0" izz="802"/>
    </inertial>
  </link>

  <!-- ── AXLE BEAMS — Z=−0.4 (was −0.5) ────────────────────────────────
       Compensates for the chassis-sag under gravity:
         per-wheel sprung mass m ≈ 692 kg
         k = 70 000 N/m  →  Δ = m·g/k ≈ 0.097 m
       After the truck settles, the wheel centres rise ~0.1 m relative to
       chassis (spring compresses), so the axle moves up 0.1 m to keep
       coincident with the actual wheel-centre line.
  ─────────────────────────────────────────────────────────────────────── -->
  <!-- Front axle beam: spans ±1.2 m to reach tyre centres -->
  <joint name="chassis_to_front_axle_beam" type="fixed">
    <parent link="chassis"/>
    <child link="front_axle_beam"/>
    <origin xyz="1.5 0 -0.4" rpy="1.5708 0 0"/>
  </joint>
  <link name="front_axle_beam">
    <visual><geometry><cylinder radius="0.08" length="2.4"/></geometry></visual>
    <collision><geometry><cylinder radius="0.08" length="2.4"/></geometry></collision>
    <inertial>
      <mass value="120.0"/>
      <!-- cylinder r=0.08 l=2.4: same inertia as before -->
      <inertia ixx="57.79" ixy="0" ixz="0" iyy="0.384" iyz="0" izz="57.79"/>
    </inertial>
  </link>

  <!-- Mid axle beam: X=−0.5, Z=−0.4 (raised 0.1 m for chassis-sag) -->
  <joint name="chassis_to_mid_axle_beam" type="fixed">
    <parent link="chassis"/>
    <child link="mid_axle_beam"/>
    <origin xyz="-0.5 0 -0.4" rpy="1.5708 0 0"/>
  </joint>
  <link name="mid_axle_beam">
    <visual><geometry><cylinder radius="0.08" length="2.4"/></geometry></visual>
    <collision><geometry><cylinder radius="0.08" length="2.4"/></geometry></collision>
    <inertial>
      <mass value="120.0"/>
      <!-- extended to 2.4 m → same inertia as front beam -->
      <inertia ixx="57.79" ixy="0" ixz="0" iyy="0.384" iyz="0" izz="57.79"/>
    </inertial>
  </link>

  <!-- Rear axle beam: Z=−0.4 (raised 0.1 m for chassis-sag) -->
  <joint name="chassis_to_rear_axle_beam" type="fixed">
    <parent link="chassis"/>
    <child link="rear_axle_beam"/>
    <origin xyz="-1.5 0 -0.4" rpy="1.5708 0 0"/>
  </joint>
  <link name="rear_axle_beam">
    <visual><geometry><cylinder radius="0.08" length="2.4"/></geometry></visual>
    <collision><geometry><cylinder radius="0.08" length="2.4"/></geometry></collision>
    <inertial>
      <mass value="120.0"/>
      <inertia ixx="57.79" ixy="0" ixz="0" iyy="0.384" iyz="0" izz="57.79"/>
    </inertial>
  </link>

  <!-- ── VERTICAL SUSPENSION STRUTS ─────────────────────────────────────
       Each strut is a fixed visual bar from the chassis frame (Z=0 relative)
       straight down to the axle level (Z=−0.5 relative).
       Parent = chassis so all 6 bars share the same reference frame.
       Strut centre is at Z=−0.25 (half of 0.5 m span).
       The front struts coincide with the fl/fr steer-rotation (Z) axis
       at their bottom end (Z=−0.5), which is now the steer-mount position.
  ─────────────────────────────────────────────────────────────────────── -->
  <!-- Inertia for strut box 0.07 × 0.07 × 0.5, m=10 kg:
       Ixx=Iyy = 10*(0.07²+0.5²)/12 = 0.212    Izz = 10*(0.07²+0.07²)/12 = 0.008 -->

  <!-- Front-LEFT suspension bar.
       Y shifted inboard by 0.185 m (= wheel_width/2 + bar_width/2 = 0.15 + 0.035)
       so the bar sits flush against the inner face of the wheel — visible
       instead of buried inside the wheel disc. -->
  <joint name="chassis_to_fl_suspension_bar" type="fixed">
    <parent link="chassis"/>
    <child link="fl_suspension_bar"/>
    <origin xyz="1.5 1.015 -0.25" rpy="0 0 0"/>
  </joint>
  <link name="fl_suspension_bar">
    <visual>
      <geometry><box size="0.07 0.07 0.5"/></geometry>
      <material name="suspension_orange"><color rgba="1.0 0.55 0.0 1.0"/></material>
    </visual>
    <collision>
      <geometry><box size="0.07 0.07 0.5"/></geometry>
    </collision>
    <inertial><mass value="10.0"/>
      <inertia ixx="0.212" ixy="0" ixz="0" iyy="0.212" iyz="0" izz="0.008"/>
    </inertial>
  </link>

  <!-- Front-RIGHT suspension bar (Y shifted inboard by 0.185 m). -->
  <joint name="chassis_to_fr_suspension_bar" type="fixed">
    <parent link="chassis"/>
    <child link="fr_suspension_bar"/>
    <origin xyz="1.5 -1.015 -0.25" rpy="0 0 0"/>
  </joint>
  <link name="fr_suspension_bar">
    <visual>
      <geometry><box size="0.07 0.07 0.5"/></geometry>
      <material name="suspension_orange"><color rgba="1.0 0.55 0.0 1.0"/></material>
    </visual>
    <collision>
      <geometry><box size="0.07 0.07 0.5"/></geometry>
    </collision>
    <inertial><mass value="10.0"/>
      <inertia ixx="0.212" ixy="0" ixz="0" iyy="0.212" iyz="0" izz="0.008"/>
    </inertial>
  </link>

  <!-- Mid/rear struts parented to the RAILS so positions stay in rail-local
       frame (rails are fixed to chassis, so dynamics are identical, but
       the origin numbers directly match the spring origin offsets).
       Each strut hangs from the rail face down to the hub/axle level.
       left_rail at Y=+0.9 from chassis → hub at Y=+0.3 in rail frame = Y=+1.2 chassis.
       right_rail at Y=−0.9 from chassis → hub at Y=−0.3 in rail frame = Y=−1.2 chassis. -->

  <!-- Mid-LEFT suspension bar (child of left_rail).
       rail-frame Y: 0.3 → 0.115 (= 0.3 − 0.185)  →  chassis Y: 0.9+0.115 = 1.015 -->
  <joint name="left_rail_to_ml_suspension_bar" type="fixed">
    <parent link="left_rail"/>
    <child link="ml_suspension_bar"/>
    <origin xyz="-0.5 0.115 -0.25" rpy="0 0 0"/>
  </joint>
  <link name="ml_suspension_bar">
    <visual>
      <geometry><box size="0.07 0.07 0.5"/></geometry>
      <material name="suspension_orange"><color rgba="1.0 0.55 0.0 1.0"/></material>
    </visual>
    <collision>
      <geometry><box size="0.07 0.07 0.5"/></geometry>
    </collision>
    <inertial><mass value="10.0"/>
      <inertia ixx="0.212" ixy="0" ixz="0" iyy="0.212" iyz="0" izz="0.008"/>
    </inertial>
  </link>

  <!-- Mid-RIGHT suspension bar.  rail-frame Y: −0.3 → −0.115 -->
  <joint name="right_rail_to_mr_suspension_bar" type="fixed">
    <parent link="right_rail"/>
    <child link="mr_suspension_bar"/>
    <origin xyz="-0.5 -0.115 -0.25" rpy="0 0 0"/>
  </joint>
  <link name="mr_suspension_bar">
    <visual>
      <geometry><box size="0.07 0.07 0.5"/></geometry>
      <material name="suspension_orange"><color rgba="1.0 0.55 0.0 1.0"/></material>
    </visual>
    <collision>
      <geometry><box size="0.07 0.07 0.5"/></geometry>
    </collision>
    <inertial><mass value="10.0"/>
      <inertia ixx="0.212" ixy="0" ixz="0" iyy="0.212" iyz="0" izz="0.008"/>
    </inertial>
  </link>

  <!-- Rear-LEFT suspension bar.  rail-frame Y: 0.3 → 0.115 -->
  <joint name="left_rail_to_rl_suspension_bar" type="fixed">
    <parent link="left_rail"/>
    <child link="rl_suspension_bar"/>
    <origin xyz="-1.5 0.115 -0.25" rpy="0 0 0"/>
  </joint>
  <link name="rl_suspension_bar">
    <visual>
      <geometry><box size="0.07 0.07 0.5"/></geometry>
      <material name="suspension_orange"><color rgba="1.0 0.55 0.0 1.0"/></material>
    </visual>
    <collision>
      <geometry><box size="0.07 0.07 0.5"/></geometry>
    </collision>
    <inertial><mass value="10.0"/>
      <inertia ixx="0.212" ixy="0" ixz="0" iyy="0.212" iyz="0" izz="0.008"/>
    </inertial>
  </link>

  <!-- Rear-RIGHT suspension bar.  rail-frame Y: −0.3 → −0.115 -->
  <joint name="right_rail_to_rr_suspension_bar" type="fixed">
    <parent link="right_rail"/>
    <child link="rr_suspension_bar"/>
    <origin xyz="-1.5 -0.115 -0.25" rpy="0 0 0"/>
  </joint>
  <link name="rr_suspension_bar">
    <visual>
      <geometry><box size="0.07 0.07 0.5"/></geometry>
      <material name="suspension_orange"><color rgba="1.0 0.55 0.0 1.0"/></material>
    </visual>
    <collision>
      <geometry><box size="0.07 0.07 0.5"/></geometry>
    </collision>
    <inertial><mass value="10.0"/>
      <inertia ixx="0.212" ixy="0" ixz="0" iyy="0.212" iyz="0" izz="0.008"/>
    </inertial>
  </link>

  <!-- ============================================================== -->
  <!-- 3.  DRIVER DECK                                                  -->
  <!-- ============================================================== -->
  <joint name="chassis_to_deck" type="fixed">
    <parent link="chassis"/>
    <child link="driver_deck"/>
    <origin xyz="1.0 0 0.75" rpy="0 0 0"/>
  </joint>
  <link name="driver_deck">
    <visual><geometry><box size="1.5 1.8 1.5"/></geometry></visual>
    <collision><geometry><box size="1.5 1.8 1.5"/></geometry></collision>
    <inertial>
      <mass value="500.0"/>
      <!--
        [PHYSICS] CORRECTED INERTIA.  box 1.5 m (X) × 1.8 m (Y) × 1.5 m (Z):
          Ixx = 500*(Y²+Z²)/12 = 500*(3.24+2.25)/12 = 500*5.49/12 = 228.75 kg·m²
          Iyy = 500*(X²+Z²)/12 = 500*(2.25+2.25)/12 = 500*4.50/12 = 187.50 kg·m²
          Izz = 500*(X²+Y²)/12 = 500*(2.25+3.24)/12 = 500*5.49/12 = 228.75 kg·m²
        ORIGINAL had Ixx=135=Izz which is  500*Y²/12 only — missed the second term.
        This caused unrealistic pitch/roll inertia (~40% too low).
      -->
      <inertia ixx="228.75" ixy="0" ixz="0"
               iyy="187.50" iyz="0"
               izz="228.75"/>
    </inertial>
  </link>

  <!-- ============================================================== -->
  <!-- 4.  FRONT SUSPENSION + STEERING WHEELS                          -->
  <!--     [PHYSICS] suspension spring: 100000 → 70000 N/m            -->
  <!--     [PHYSICS] steering joint friction: 5.0 → 1.5 Nm            -->
  <!-- ============================================================== -->

  <!-- ── FRONT LEFT ── -->
  <!-- steering_joint placed directly on fl_suspension_bar.
       Bar origin is at chassis(1.5,1.2,−0.25); offset −0.25 in Z puts the
       steering axis at chassis(1.5,1.2,−0.5) = axle / wheel-centre level. -->
  <joint name="fl_steering_joint" type="revolute">
    <parent link="fl_suspension_bar"/>
    <child link="fl_steer_knuckle"/>
    <origin xyz="0 0 -0.25" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.6109" upper="0.6109" effort="2000" velocity="1.5"/>
    <!-- [PHYSICS] friction 5.0→1.5: reduces steering stiction for faster servo response -->
    <dynamics damping="30.0" friction="1.5"/>
  </joint>
  <link name="fl_steer_knuckle">
    <inertial><mass value="15.0"/><inertia ixx="0.05" ixy="0" ixz="0" iyy="0.05" iyz="0" izz="0.05"/></inertial>
  </link>

  <joint name="fl_spring" type="prismatic">
    <parent link="fl_steer_knuckle"/>
    <child link="fl_hub"/>
    <!-- [GEOM] Y offset = +0.185 m compensates for the suspension bar
         being shifted inboard, so the wheel stays at chassis Y=+1.2.
         This is a real scrub-radius / kingpin-offset (the wheel pivots
         around an axis 0.185 m inboard of its centre line). -->
    <origin xyz="0 0.185 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.15" upper="0.15" effort="50000" velocity="2.0"/>
    <!-- [PHYSICS] spring_stiffness 100000→70000: fn=1.5 Hz at 777 kg/wheel -->
    <dynamics damping="4500.0" friction="100.0" spring_stiffness="70000.0" spring_reference="0"/>
  </joint>
  <link name="fl_hub">
    <!-- hub has no visual — the axle beam already shows where the hubs are -->
    <inertial><mass value="20.0"/><inertia ixx="0.05" ixy="0" ixz="0" iyy="0.05" iyz="0" izz="0.05"/></inertial>
  </link>
  <joint name="fl_hub_to_fl_wheel" type="continuous">
    <parent link="fl_hub"/>
    <child link="fl_wheel"/>
    <origin xyz="0 0 0" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>
  <link name="fl_wheel">
    <visual><geometry><cylinder radius="0.5" length="0.3"/></geometry></visual>
    <collision><geometry><cylinder radius="0.5" length="0.3"/></geometry></collision>
    <!-- cylinder r=0.5 l=0.3 m=80: Ixx=Iyy=m(3r²+l²)/12=5.6  Izz=mr²/2=10 ✓ -->
    <inertial><mass value="80.0"/><inertia ixx="5.6" ixy="0" ixz="0" iyy="5.6" iyz="0" izz="10.0"/></inertial>
  </link>

  <!-- ── FRONT RIGHT ── -->
  <!-- steering_joint placed directly on fr_suspension_bar -->
  <joint name="fr_steering_joint" type="revolute">
    <parent link="fr_suspension_bar"/>
    <child link="fr_steer_knuckle"/>
    <origin xyz="0 0 -0.25" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.6109" upper="0.6109" effort="2000" velocity="1.5"/>
    <dynamics damping="30.0" friction="1.5"/>
  </joint>
  <link name="fr_steer_knuckle">
    <inertial><mass value="15.0"/><inertia ixx="0.05" ixy="0" ixz="0" iyy="0.05" iyz="0" izz="0.05"/></inertial>
  </link>

  <joint name="fr_spring" type="prismatic">
    <parent link="fr_steer_knuckle"/>
    <child link="fr_hub"/>
    <!-- [GEOM] Y offset = −0.185 m  (mirror of fl_spring) -->
    <origin xyz="0 -0.185 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.15" upper="0.15" effort="50000" velocity="2.0"/>
    <!-- [PHYSICS] spring_stiffness 100000→70000 -->
    <dynamics damping="4500.0" friction="100.0" spring_stiffness="70000.0" spring_reference="0"/>
  </joint>
  <link name="fr_hub">
    <inertial><mass value="20.0"/><inertia ixx="0.05" ixy="0" ixz="0" iyy="0.05" iyz="0" izz="0.05"/></inertial>
  </link>
  <joint name="fr_hub_to_fr_wheel" type="continuous">
    <parent link="fr_hub"/>
    <child link="fr_wheel"/>
    <origin xyz="0 0 0" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>
  <link name="fr_wheel">
    <visual><geometry><cylinder radius="0.5" length="0.3"/></geometry></visual>
    <collision><geometry><cylinder radius="0.5" length="0.3"/></geometry></collision>
    <inertial><mass value="80.0"/><inertia ixx="5.6" ixy="0" ixz="0" iyy="5.6" iyz="0" izz="10.0"/></inertial>
  </link>

  <!-- ============================================================== -->
  <!-- 5.  MID / REAR DRIVE AXLES                                      -->
  <!--     [PHYSICS] spring_stiffness 100000 → 70000 N/m (all 4)      -->
  <!-- ============================================================== -->

  <!-- ── MID LEFT (X=−0.5, moved rearward slightly from −0.3) ── -->
  <joint name="left_rail_to_ml_spring" type="prismatic">
    <parent link="left_rail"/>
    <child link="ml_hub"/>
    <origin xyz="-0.5 0.3 -0.5" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.15" upper="0.15" effort="50000" velocity="2.0"/>
    <!-- [PHYSICS] 100000→70000 -->
    <dynamics damping="4500.0" friction="100.0" spring_stiffness="70000.0" spring_reference="0"/>
  </joint>
  <link name="ml_hub">
    <inertial><mass value="20.0"/><inertia ixx="0.05" ixy="0" ixz="0" iyy="0.05" iyz="0" izz="0.05"/></inertial>
  </link>
  <joint name="ml_hub_to_ml_wheel" type="continuous">
    <parent link="ml_hub"/>
    <child link="ml_wheel"/>
    <origin xyz="0 0 0" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>
  <link name="ml_wheel">
    <visual><geometry><cylinder radius="0.5" length="0.3"/></geometry></visual>
    <collision><geometry><cylinder radius="0.5" length="0.3"/></geometry></collision>
    <inertial><mass value="80.0"/><inertia ixx="5.6" ixy="0" ixz="0" iyy="5.6" iyz="0" izz="10.0"/></inertial>
  </link>

  <!-- ── MID RIGHT (X=−0.5) ── -->
  <joint name="right_rail_to_mr_spring" type="prismatic">
    <parent link="right_rail"/>
    <child link="mr_hub"/>
    <origin xyz="-0.5 -0.3 -0.5" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.15" upper="0.15" effort="50000" velocity="2.0"/>
    <!-- [PHYSICS] 100000→70000 -->
    <dynamics damping="4500.0" friction="100.0" spring_stiffness="70000.0" spring_reference="0"/>
  </joint>
  <link name="mr_hub">
    <inertial><mass value="20.0"/><inertia ixx="0.05" ixy="0" ixz="0" iyy="0.05" iyz="0" izz="0.05"/></inertial>
  </link>
  <joint name="mr_hub_to_mr_wheel" type="continuous">
    <parent link="mr_hub"/>
    <child link="mr_wheel"/>
    <origin xyz="0 0 0" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>
  <link name="mr_wheel">
    <visual><geometry><cylinder radius="0.5" length="0.3"/></geometry></visual>
    <collision><geometry><cylinder radius="0.5" length="0.3"/></geometry></collision>
    <inertial><mass value="80.0"/><inertia ixx="5.6" ixy="0" ixz="0" iyy="5.6" iyz="0" izz="10.0"/></inertial>
  </link>

  <!-- ── REAR LEFT (X=-1.5) ── -->
  <joint name="left_rail_to_rl_spring" type="prismatic">
    <parent link="left_rail"/>
    <child link="rl_hub"/>
    <origin xyz="-1.5 0.3 -0.5" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.15" upper="0.15" effort="50000" velocity="2.0"/>
    <!-- [PHYSICS] 100000→70000 -->
    <dynamics damping="4500.0" friction="100.0" spring_stiffness="70000.0" spring_reference="0"/>
  </joint>
  <link name="rl_hub">
    <inertial><mass value="20.0"/><inertia ixx="0.05" ixy="0" ixz="0" iyy="0.05" iyz="0" izz="0.05"/></inertial>
  </link>
  <joint name="rl_hub_to_rl_wheel" type="continuous">
    <parent link="rl_hub"/>
    <child link="rl_wheel"/>
    <origin xyz="0 0 0" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>
  <link name="rl_wheel">
    <visual><geometry><cylinder radius="0.5" length="0.3"/></geometry></visual>
    <collision><geometry><cylinder radius="0.5" length="0.3"/></geometry></collision>
    <inertial><mass value="80.0"/><inertia ixx="5.6" ixy="0" ixz="0" iyy="5.6" iyz="0" izz="10.0"/></inertial>
  </link>

  <!-- ── REAR RIGHT (X=-1.5) ── -->
  <joint name="right_rail_to_rr_spring" type="prismatic">
    <parent link="right_rail"/>
    <child link="rr_hub"/>
    <origin xyz="-1.5 -0.3 -0.5" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.15" upper="0.15" effort="50000" velocity="2.0"/>
    <!-- [PHYSICS] 100000→70000 -->
    <dynamics damping="4500.0" friction="100.0" spring_stiffness="70000.0" spring_reference="0"/>
  </joint>
  <link name="rr_hub">
    <inertial><mass value="20.0"/><inertia ixx="0.05" ixy="0" ixz="0" iyy="0.05" iyz="0" izz="0.05"/></inertial>
  </link>
  <joint name="rr_hub_to_rr_wheel" type="continuous">
    <parent link="rr_hub"/>
    <child link="rr_wheel"/>
    <origin xyz="0 0 0" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>
