  </gazebo>

  <!-- ============================================================== -->
  <!-- 8.  ODOMETRY PUBLISHER                                          -->
  <!-- ============================================================== -->
  <gazebo>
    <plugin filename="gz-sim-odometry-publisher-system"
            name="gz::sim::systems::OdometryPublisher">
      <odom_frame>odom</odom_frame>
      <robot_base_frame>base_link</robot_base_frame>
      <dimensions>3</dimensions>
      <odom_publish_frequency>100</odom_publish_frequency>
    </plugin>
  </gazebo>

  <!-- ============================================================== -->
  <!-- 9.  STEERING POSITION CONTROLLERS  [PHYSICS]                    -->
  <!--     p_gain 500→1500, i_gain 1→2, d_gain 50→100                 -->
  <!--     Reason: faster servo bandwidth without overshoot.           -->
  <!--     Higher P tracks the Ackermann setpoint more tightly at 1kHz -->
  <!-- ============================================================== -->
  <gazebo>
    <plugin filename="gz-sim-joint-position-controller-system"
            name="gz::sim::systems::JointPositionController">
      <joint_name>fl_steering_joint</joint_name>
      <topic>/truck/fl_steer/cmd_pos</topic>
      <p_gain>1500</p_gain>
      <i_gain>2.0</i_gain>
      <d_gain>100</d_gain>
    </plugin>

    <plugin filename="gz-sim-joint-position-controller-system"
            name="gz::sim::systems::JointPositionController">
      <joint_name>fr_steering_joint</joint_name>
      <topic>/truck/fr_steer/cmd_pos</topic>
      <p_gain>1500</p_gain>
      <i_gain>2.0</i_gain>
      <d_gain>100</d_gain>
    </plugin>

    <!-- ── SUSPENSION SPRING-DAMPERS ─────────────────────────────────────
         URDF <dynamics spring_stiffness=…> is dropped by the URDF→SDF
         converter in Gz Harmonic, so the prismatic spring joints get
         NO restoring force from the dynamics tag.
         We restore spring behaviour actively via JointPositionController
         in PD mode: target = 0, P = stiffness, D = damping.
         Force applied to joint: F = −P·x − D·ẋ  (exact spring-damper).
           k = 70 000 N/m   →  fn ≈ 1.5 Hz at 692 kg/wheel sprung mass
           c = 4 500 N·s/m  →  ζ ≈ 0.32 (under-damped, 2-3 visible bounces)
    ─────────────────────────────────────────────────────────────────── -->
    <plugin filename="gz-sim-joint-position-controller-system"
            name="gz::sim::systems::JointPositionController">
      <joint_name>fl_spring</joint_name>
      <p_gain>70000</p_gain>
      <i_gain>0.0</i_gain>
      <d_gain>4500</d_gain>
      <initial_position>0.0</initial_position>
      <cmd_max>100000</cmd_max>
      <cmd_min>-100000</cmd_min>
    </plugin>
    <plugin filename="gz-sim-joint-position-controller-system"
            name="gz::sim::systems::JointPositionController">
      <joint_name>fr_spring</joint_name>
      <p_gain>70000</p_gain>
      <i_gain>0.0</i_gain>
      <d_gain>4500</d_gain>
      <initial_position>0.0</initial_position>
      <cmd_max>100000</cmd_max>
      <cmd_min>-100000</cmd_min>
    </plugin>
    <plugin filename="gz-sim-joint-position-controller-system"
            name="gz::sim::systems::JointPositionController">
      <joint_name>left_rail_to_ml_spring</joint_name>
      <p_gain>70000</p_gain>
      <i_gain>0.0</i_gain>
      <d_gain>4500</d_gain>
      <initial_position>0.0</initial_position>
      <cmd_max>100000</cmd_max>
      <cmd_min>-100000</cmd_min>
    </plugin>
    <plugin filename="gz-sim-joint-position-controller-system"
            name="gz::sim::systems::JointPositionController">
      <joint_name>right_rail_to_mr_spring</joint_name>
      <p_gain>70000</p_gain>
      <i_gain>0.0</i_gain>
      <d_gain>4500</d_gain>
      <initial_position>0.0</initial_position>
      <cmd_max>100000</cmd_max>
      <cmd_min>-100000</cmd_min>
    </plugin>
    <plugin filename="gz-sim-joint-position-controller-system"
            name="gz::sim::systems::JointPositionController">
      <joint_name>left_rail_to_rl_spring</joint_name>
      <p_gain>70000</p_gain>
      <i_gain>0.0</i_gain>
      <d_gain>4500</d_gain>
      <initial_position>0.0</initial_position>
      <cmd_max>100000</cmd_max>
      <cmd_min>-100000</cmd_min>
    </plugin>
    <plugin filename="gz-sim-joint-position-controller-system"
            name="gz::sim::systems::JointPositionController">
      <joint_name>right_rail_to_rr_spring</joint_name>
      <p_gain>70000</p_gain>
      <i_gain>0.0</i_gain>
      <d_gain>4500</d_gain>
      <initial_position>0.0</initial_position>
      <cmd_max>100000</cmd_max>
      <cmd_min>-100000</cmd_min>
    </plugin>

    <!-- ── TRAILER SPRING PD CONTROLLERS  (same k=70 000, c=4 500) ─── -->
    <plugin filename="gz-sim-joint-position-controller-system"
            name="gz::sim::systems::JointPositionController">
      <joint_name>trailer_left_rail_to_tfl_spring</joint_name>
      <p_gain>70000</p_gain>
      <i_gain>0.0</i_gain>
      <d_gain>4500</d_gain>
      <initial_position>0.0</initial_position>
      <cmd_max>100000</cmd_max>
      <cmd_min>-100000</cmd_min>
    </plugin>
    <plugin filename="gz-sim-joint-position-controller-system"
            name="gz::sim::systems::JointPositionController">
      <joint_name>trailer_right_rail_to_tfr_spring</joint_name>
      <p_gain>70000</p_gain>
      <i_gain>0.0</i_gain>
      <d_gain>4500</d_gain>
      <initial_position>0.0</initial_position>
      <cmd_max>100000</cmd_max>
      <cmd_min>-100000</cmd_min>
    </plugin>
    <plugin filename="gz-sim-joint-position-controller-system"
            name="gz::sim::systems::JointPositionController">
      <joint_name>trailer_left_rail_to_trl_spring</joint_name>
      <p_gain>70000</p_gain>
      <i_gain>0.0</i_gain>
      <d_gain>4500</d_gain>
      <initial_position>0.0</initial_position>
      <cmd_max>100000</cmd_max>
      <cmd_min>-100000</cmd_min>
    </plugin>
    <plugin filename="gz-sim-joint-position-controller-system"
            name="gz::sim::systems::JointPositionController">
      <joint_name>trailer_right_rail_to_trr_spring</joint_name>
      <p_gain>70000</p_gain>
      <i_gain>0.0</i_gain>
      <d_gain>4500</d_gain>
      <initial_position>0.0</initial_position>
      <cmd_max>100000</cmd_max>
      <cmd_min>-100000</cmd_min>
    </plugin>

    <plugin filename="gz-sim-joint-state-publisher-system"
            name="gz::sim::systems::JointStatePublisher"/>

    <!-- ── REAR-WHEEL DRIVE (same 4 joints, same topic /truck/drive) ── -->
    <plugin filename="gz-sim-joint-controller-system"
            name="gz::sim::systems::JointController">
      <joint_name>ml_hub_to_ml_wheel</joint_name>
      <topic>/truck/drive</topic>
    </plugin>
    <plugin filename="gz-sim-joint-controller-system"
            name="gz::sim::systems::JointController">
      <joint_name>mr_hub_to_mr_wheel</joint_name>
      <topic>/truck/drive</topic>
    </plugin>
    <plugin filename="gz-sim-joint-controller-system"
            name="gz::sim::systems::JointController">
      <joint_name>rl_hub_to_rl_wheel</joint_name>
      <topic>/truck/drive</topic>
    </plugin>
    <plugin filename="gz-sim-joint-controller-system"
            name="gz::sim::systems::JointController">
      <joint_name>rr_hub_to_rr_wheel</joint_name>
      <topic>/truck/drive</topic>
    </plugin>
  </gazebo>

  <!-- ============================================================== -->
  <!-- 10.  SENSORS                                                    -->
  <!-- ============================================================== -->
  <gazebo reference="imu_link">
    <sensor name="truck_imu" type="imu">
      <always_on>1</always_on>
      <update_rate>100</update_rate>
      <visualize>false</visualize>
      <topic>imu</topic>
      <imu>
        <angular_velocity>
          <x><noise type="gaussian"><mean>0.0</mean><stddev>2e-4</stddev></noise></x>
          <y><noise type="gaussian"><mean>0.0</mean><stddev>2e-4</stddev></noise></y>
          <z><noise type="gaussian"><mean>0.0</mean><stddev>2e-4</stddev></noise></z>
        </angular_velocity>
        <linear_acceleration>
          <x><noise type="gaussian"><mean>0.0</mean><stddev>1.7e-2</stddev></noise></x>
          <y><noise type="gaussian"><mean>0.0</mean><stddev>1.7e-2</stddev></noise></y>
          <z><noise type="gaussian"><mean>0.0</mean><stddev>1.7e-2</stddev></noise></z>
        </linear_acceleration>
      </imu>
    </sensor>
  </gazebo>

  <link name="lidar_link">
    <visual>
      <geometry>
        <cylinder radius="0.05" length="0.1"/>
      </geometry>
      <material name="black">
        <color rgba="0.1 0.1 0.1 1"/>
      </material>
    </visual>
  </link>

  <joint name="lidar_joint" type="fixed">
    <parent link="driver_deck"/>
    <child link="lidar_link"/>
    <!-- Place it 0.85m above the driver_deck origin (just above the roof), angled slightly downwards (pitch = 0.1 rad) -->
    <origin xyz="0.0 0.0 0.85" rpy="0 0.1 0"/>
  </joint>

  <gazebo reference="lidar_link">
    <sensor name="truck_lidar" type="gpu_lidar">
      <pose>0 0 0 0 0 0</pose>
      <always_on>true</always_on>
      <topic>/lidar</topic>
      <gz_frame_id>lidar_link</gz_frame_id>
      <update_rate>10</update_rate>
      <visualize>false</visualize>
      <lidar>
        <scan>
          <horizontal>
            <samples>256</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
          <vertical>
            <samples>8</samples>
            <resolution>1</resolution>
            <min_angle>-0.26</min_angle>
            <max_angle>0.0</max_angle>
          </vertical>
        </scan>
        <range>
          <min>0.5</min>
          <max>100.0</max>
          <resolution>0.01</resolution>
        </range>
      </lidar>
    </sensor>
  </gazebo>

  <gazebo reference="gps_link">
    <sensor name="truck_gps" type="navsat">
      <always_on>1</always_on>
      <update_rate>10</update_rate>
      <topic>gps/fix</topic>
      <navsat>
        <position_sensing>
          <horizontal>
            <noise type="gaussian"><mean>0.0</mean><stddev>0.1</stddev></noise>
          </horizontal>
          <vertical>
            <noise type="gaussian"><mean>0.0</mean><stddev>0.1</stddev></noise>
          </vertical>
        </position_sensing>
      </navsat>
    </sensor>
  </gazebo>

  <gazebo>
    <plugin name="pacejka_plugin" filename="libpacejka_plugin.so">
      <vehicle_mass>4750.0</vehicle_mass>
      <unsprung_mass>85.0</unsprung_mass>
      <wheel_radius>0.5</wheel_radius>
      <wheel_width>0.3</wheel_width>
      <wheelbase>2.5</wheelbase>
      <track_width>2.4</track_width>
      <cg_height>0.98</cg_height>
      <max_steer_rad>0.5236</max_steer_rad>
      
      <wheel name="fl_wheel">
        <joint_name>fl_steering_joint</joint_name>
        <is_steerable>true</is_steerable>
        <ks>75000.0</ks>
        <cs>5200.0</cs>
        <mu>0.85</mu>
        <pacejka_B>10.0</pacejka_B>
        <pacejka_C>1.65</pacejka_C>
      </wheel>

      <wheel name="fr_wheel">
        <joint_name>fr_steering_joint</joint_name>
        <is_steerable>true</is_steerable>
        <ks>75000.0</ks>
        <cs>5200.0</cs>
        <mu>0.85</mu>
        <pacejka_B>10.0</pacejka_B>
        <pacejka_C>1.65</pacejka_C>
      </wheel>

      <wheel name="ml_wheel">
        <joint_name>ml_hub_to_ml_wheel</joint_name>
        <is_steerable>false</is_steerable>
        <ks>80000.0</ks>
        <cs>5500.0</cs>
        <mu>0.85</mu>
        <pacejka_B>12.0</pacejka_B>
        <pacejka_C>1.65</pacejka_C>
      </wheel>

      <wheel name="mr_wheel">
        <joint_name>mr_hub_to_mr_wheel</joint_name>
        <is_steerable>false</is_steerable>
        <ks>80000.0</ks>
        <cs>5500.0</cs>
        <mu>0.85</mu>
        <pacejka_B>12.0</pacejka_B>
        <pacejka_C>1.65</pacejka_C>
      </wheel>

      <wheel name="rl_wheel">
        <joint_name>rl_hub_to_rl_wheel</joint_name>
        <is_steerable>false</is_steerable>
        <ks>80000.0</ks>
        <cs>5500.0</cs>
        <mu>0.85</mu>
        <pacejka_B>12.0</pacejka_B>
        <pacejka_C>1.65</pacejka_C>
      </wheel>

      <wheel name="rr_wheel">
        <joint_name>rr_hub_to_rr_wheel</joint_name>
        <is_steerable>false</is_steerable>
        <ks>80000.0</ks>
        <cs>5500.0</cs>
        <mu>0.85</mu>
        <pacejka_B>12.0</pacejka_B>
        <pacejka_C>1.65</pacejka_C>
      </wheel>

      <wheel name="tfl_wheel">
        <joint_name>tfl_hub_to_tfl_wheel</joint_name>
        <is_steerable>false</is_steerable>
        <ks>80000.0</ks>
        <cs>5500.0</cs>
        <mu>0.85</mu>
        <pacejka_B>12.0</pacejka_B>
        <pacejka_C>1.65</pacejka_C>
      </wheel>

      <wheel name="tfr_wheel">
        <joint_name>tfr_hub_to_tfr_wheel</joint_name>
        <is_steerable>false</is_steerable>
        <ks>80000.0</ks>
        <cs>5500.0</cs>
        <mu>0.85</mu>
        <pacejka_B>12.0</pacejka_B>
        <pacejka_C>1.65</pacejka_C>
      </wheel>

      <wheel name="trl_wheel">
        <joint_name>trl_hub_to_trl_wheel</joint_name>
        <is_steerable>false</is_steerable>
        <ks>80000.0</ks>
        <cs>5500.0</cs>
        <mu>0.85</mu>
        <pacejka_B>12.0</pacejka_B>
        <pacejka_C>1.65</pacejka_C>
      </wheel>

      <wheel name="trr_wheel">
        <joint_name>trr_hub_to_trr_wheel</joint_name>
        <is_steerable>false</is_steerable>
        <ks>80000.0</ks>
        <cs>5500.0</cs>
        <mu>0.85</mu>
        <pacejka_B>12.0</pacejka_B>
        <pacejka_C>1.65</pacejka_C>
      </wheel>

    </plugin>
  </gazebo>

</robot>
