  <joint name="imu_joint" type="fixed">
    <parent link="chassis"/>
    <child link="imu_link"/>
    <origin xyz="0 0 0.25" rpy="0 0 0"/>
  </joint>
  <link name="imu_link"/>

  <joint name="gps_joint" type="fixed">
    <parent link="driver_deck"/>
    <child link="gps_link"/>
    <origin xyz="0 0 0.75" rpy="0 0 0"/>
  </joint>
  <link name="gps_link"/>

  <!-- ============================================================== -->
  <!-- 7.  PER-WHEEL CONTACT SURFACE  [PHYSICS]                        -->
  <!--                                                                  -->
  <!--  Rubber tyre on dry concrete:                                    -->
  <!--    mu1  = 0.85  (longitudinal – rolling/braking direction)       -->
  <!--    mu2  = 0.75  (lateral – cornering)                            -->
  <!--    kp   = 1e6 N/m (tyre contact stiffness; ground uses 1e7)      -->
  <!--    kd   = 50 N·s/m                                               -->
  <!--    slip1 = 0.002 (1% longitudinal compliance)                    -->
  <!--    slip2 = 0.005 (0.5% lateral compliance)                       -->
  <!--    minDepth = 0.002 m (2 mm tyre deformation before contact)     -->
  <!--    maxContacts = 3  (performance: limit contact points per wheel) -->
  <!-- ============================================================== -->

  <!-- front-left wheel -->
  <gazebo reference="fl_wheel">
    <mu1>0.85</mu1>
    <mu2>0.75</mu2>
    <kp>1000000</kp>
    <kd>50</kd>
    <slip1>0.002</slip1>
    <slip2>0.005</slip2>
    <minDepth>0.002</minDepth>
    <maxVel>0.2</maxVel>
    <maxContacts>3</maxContacts>
    <selfCollide>false</selfCollide>
  </gazebo>

  <!-- front-right wheel -->
  <gazebo reference="fr_wheel">
    <mu1>0.85</mu1>
    <mu2>0.75</mu2>
    <kp>1000000</kp>
    <kd>50</kd>
    <slip1>0.002</slip1>
    <slip2>0.005</slip2>
    <minDepth>0.002</minDepth>
    <maxVel>0.2</maxVel>
    <maxContacts>3</maxContacts>
    <selfCollide>false</selfCollide>
  </gazebo>

  <!-- mid-left drive wheel -->
  <gazebo reference="ml_wheel">
    <mu1>0.85</mu1>
    <mu2>0.75</mu2>
    <kp>1000000</kp>
    <kd>50</kd>
    <slip1>0.002</slip1>
    <slip2>0.005</slip2>
    <minDepth>0.002</minDepth>
    <maxVel>0.2</maxVel>
    <maxContacts>3</maxContacts>
    <selfCollide>false</selfCollide>
  </gazebo>

  <!-- mid-right drive wheel -->
  <gazebo reference="mr_wheel">
    <mu1>0.85</mu1>
    <mu2>0.75</mu2>
    <kp>1000000</kp>
    <kd>50</kd>
    <slip1>0.002</slip1>
    <slip2>0.005</slip2>
    <minDepth>0.002</minDepth>
    <maxVel>0.2</maxVel>
